{
    "dependencies": {
        "@vitejs/plugin-react": "^4.3.4",
        "bcrypt": "^6.0.0",
        "bootstrap": "^5.3.8",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.0",
        "express": "^5.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongodb": "7.1.1",
        "mongoose": "^8.19.1",
        "morgan": "^1.10.1",
        "react": "^19.1.1",
        "react-dom": "^19.2.0",
        "react-router-dom": "^6.26.2",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "vite": "^7.1.10",
        "vite-express": "^0.19.0"
    },
    "scripts": {
        "start": "node server.mjs",
        "dev": "node server.mjs",
        "build": "vite build",
        "preview": "vite preview",
        "cypress:open": "cypress open",
        "cypress:run": "cypress run",
        "coverage:e2e": "cross-env CYPRESS_COVERAGE=true cypress run --spec \"cypress/e2e/*.cy.js\"",
        "coverage:report": "nyc report --reporter=text-summary --reporter=html",
        "coverage:run": "npm run coverage:e2e && npm run coverage:report",
        "coverage:run:with-server": "start-server-and-test \"cross-env CYPRESS_COVERAGE=true npm run dev\" http-get://localhost:3000/api/health \"npm run coverage:e2e && npm run coverage:report\""
    },
    "devDependencies": {
        "@cypress/code-coverage": "^4.0.3",
        "@tailwindcss/postcss": "^4.2.2",
        "autoprefixer": "^10.4.27",
        "babel-plugin-istanbul": "^8.0.0",
        "cross-env": "^10.1.0",
        "cypress": "^15.14.1",
        "nyc": "^18.0.0",
        "postcss": "^8.5.8",
        "start-server-and-test": "^3.0.2",
        "tailwindcss": "^4.2.2"
    },
    "nyc": {
        "report-dir": "coverage",
        "reporter": [
            "text-summary",
            "html"
        ],
        "all": true,
        "include": [
            "src/**/*.{js,jsx,mjs}"
        ],
        "exclude": [
            "cypress/**",
            "**/*.cy.*"
        ]
    }
}
